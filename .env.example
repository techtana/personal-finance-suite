# ── Google OAuth credentials ──────────────────────────────────────────────────
#
# Create credentials at: Google Cloud Console → APIs & Services → Credentials
#
# Choose ONE of the following OAuth client types:
#
#   OPTION A — Desktop app (recommended)
#     Client type: Desktop app
#     No client secret required.
#     Authorized JavaScript origins / Redirect URIs: not needed for Desktop type.
#
#   OPTION B — Web application
#     Client type: Web application
#     Requires VITE_GOOGLE_CLIENT_SECRET (see below).
#
#     Authorized JavaScript origins:
#       http://localhost:5173
#       https://your-vercel-domain.vercel.app
#
#     Authorized redirect URIs:
#       http://localhost:5173/auth/callback
#       https://your-vercel-domain.vercel.app/auth/callback
#
# ─────────────────────────────────────────────────────────────────────────────

VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Only needed for "Web application" client type. Leave blank for "Desktop app".
VITE_GOOGLE_CLIENT_SECRET=
